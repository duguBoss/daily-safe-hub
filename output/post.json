{
  "title": "GlassWorm行动升级：利用Zig原生插件实现多款IDE自动化感染",
  "covers": [
    "https://raw.githubusercontent.com/duguBoss/daily-safe-hub/main/assets/today/cover_01.jpg",
    "https://raw.githubusercontent.com/duguBoss/daily-safe-hub/main/assets/today/cover_02.png"
